# ===========================================
# Market Stress Tool - 환경 변수 템플릿
# 사용법: 이 파일을 .env로 복사한 뒤 실제 키를 채워넣으세요.
#   cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함되어 있음)
# ===========================================

# --- FRED API ---
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
# 무료, 즉시 발급. 32자 영숫자 키.
FRED_API_KEY=your_fred_api_key_here

# --- 한국은행 ECOS API ---
# 발급: https://ecos.bok.or.kr/api/
# 무료, 이메일 인증 필요. 일일 호출 한도 있음 (1만회/일).
ECOS_API_KEY=your_ecos_api_key_here

# --- 캐시 설정 (선택) ---
# 캐시 갱신 주기 (시간 단위). 기본 24시간.
CACHE_TTL_HOURS=24

# --- 데이터 시작일 (선택) ---
# 분석 시작일. 기본 2005-01-01 (글로벌 금융위기 이전부터 충분한 기간 확보)
DATA_START_DATE=2005-01-01

# --- 로깅 레벨 (선택) ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
