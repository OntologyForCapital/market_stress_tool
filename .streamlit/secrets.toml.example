# ===========================================
# Streamlit Cloud secrets 템플릿 (v17)
#
# 본 파일 자체는 템플릿이며 git에 커밋해도 무방합니다.
# 실제 키가 들어가는 .streamlit/secrets.toml은 .gitignore에 포함되어
# 절대 깃에 올라가지 않습니다.
#
# 사용법
# ------
# [로컬 실행]
#   .env 파일을 사용하세요 (.env.example 참고).
#   secrets.toml은 만들 필요 없음.
#
# [Streamlit Cloud 배포]
#   1) 본 파일을 참고만 하세요 (배포 환경에 업로드되지 않습니다).
#   2) https://share.streamlit.io 에서 앱 Settings > Secrets로 들어가
#      아래 값들을 TOML 형식 그대로 붙여넣고 저장합니다.
#   3) 저장하면 앱이 자동으로 재시작되며 require_env()가 st.secrets에서 키를 읽습니다.
# ===========================================

# --- FRED API ---
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY = "여기에_FRED_API_키"

# --- 한국은행 ECOS API ---
# 발급: https://ecos.bok.or.kr/api/
ECOS_API_KEY = "여기에_ECOS_API_키"

# --- 선택 항목 (필요시) ---
# CACHE_TTL_HOURS = "24"
# DATA_START_DATE = "2005-01-01"
# LOG_LEVEL = "INFO"
